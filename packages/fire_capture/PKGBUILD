# Maintainer: Mattia Procopio <matto.astro@gmail.com>
# Original AUR PKGBUILD mantainer Daniel Reibl <janos.daniel.reibl@pm.me>
# This build contains some changes that allow FireCapture to work on aarch64 and start with no path issues
pkgname=firecapture
pkgver=2.7.14
[ "$CARCH" = "aarch64" ] && pkgver="${pkgver}a" # unclear if the 'a' is always present for ARM, or just this release
pkgrel=1
pkgdesc="The leading planetary capture tool"
arch=(x86_64 aarch64)
url="http://www.firecapture.de"
license=('custom:firecapture')
depends=('libusb')
makedepends=('curl')
source=("https://www.firecapture.de/license.html")
sha256sums=(SKIP)
_filename=fire_capture.deb

prepare() {
    DL_URL="https://www.firecapture.de/download.php"
    _debtarget="FireCapture_v${pkgver}.deb"
    [ "$CARCH" = "aarch64" ] && _debtarget="firecapture_${pkgver}_aarch64.deb"
    SRC_URL="${DL_URL}?file=${_debtarget}"
    echo "  -> Downloading $_debtarget..."
    _cookies="cookie_file.tmp"
    _response=$(curl -s -c "$_cookies" "$SRC_URL")
    _question=$(echo "$_response" | grep -oP '(?<=>)\d+ \+ \d+(?= =)')
    _answer=$((_question))
    echo "    Prompt was '$_question', responding with '$_answer'"
    curl -b "$_cookies" -X POST -d "password=$_answer" "$SRC_URL" -o "$_filename"
    rm $_cookies
    ar x ${_filename} data.tar.xz
}

package() {
    echo "  -> Extracting data.tar.xz..."
    bsdtar -xf data.tar.xz -C "$pkgdir/"

    # License
    _license_dest="$pkgdir/usr/share/licenses/$pkgname"
    install -Dm644 "$srcdir/license.html" "$_license_dest/license.html"
    install -pm644 "$pkgdir/opt/FireCapture_v2.7/license.txt" "$_license_dest/license.txt"
    mv "$pkgdir/lib/" "$pkgdir/usr/lib"
    if [ -d "$pkgdir/lib" ]; then
        rmdir "$pkgdir/lib"
    fi
}
